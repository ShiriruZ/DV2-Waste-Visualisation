{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 760,
  "height": 420,
  "title": {
    "text": "Top 10 councils by recovery rate, 2023–24",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "data": {
    "url": "data/waste_lga_yearly.csv",
    "format": {
      "type": "csv",
      "parse": {
        "recovery_rate": "number",
        "total_waste_tonnes": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.financial_year == '2023-2024' && isValid(datum.recovery_rate)"
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "recovery_rate", "order": "descending"}]
    },
    {"filter": "datum.rank <= 10"}
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopRight": 4,
        "cornerRadiusBottomRight": 4
      },
      "encoding": {
        "y": {
          "field": "lga_name",
          "type": "nominal",
          "sort": "-x",
          "title": "Council"
        },
        "x": {
          "field": "recovery_rate",
          "type": "quantitative",
          "title": "Recovery rate",
          "axis": {"format": ".0%"},
          "scale": {"domain": [0, 0.85]}
        },
        "color": {
          "field": "recovery_rate",
          "type": "quantitative",
          "scale": {"scheme": "greens", "domain": [0, 1]},
          "legend": null
        },
        "tooltip": [
          {"field": "lga_name", "type": "nominal", "title": "Council"},
          {"field": "recovery_rate", "type": "quantitative", "title": "Recovery rate", "format": ".1%"},
          {"field": "total_waste_tonnes", "type": "quantitative", "title": "Total waste tonnes", "format": ",.0f"}
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#c95f28",
        "strokeWidth": 2,
        "strokeDash": [6, 3]
      },
      "encoding": {
        "x": {"datum": 0.527}
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "color": "#c95f28",
        "fontWeight": "bold",
        "fontSize": 11,
        "dx": 5,
        "dy": -5
      },
      "encoding": {
        "x": {"datum": 0.527},
        "y": {"value": 0},
        "text": {"value": "State avg 52.7%"}
      }
    }
  ]
}
