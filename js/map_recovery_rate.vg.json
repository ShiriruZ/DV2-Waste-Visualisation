{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 760,
  "height": 520,
  "title": {
    "text": "Waste recovery rate by Victorian council, 2023–24",
    "fontSize": 14,
    "fontWeight": "bold",
    "subtitle": "State average: 52.7%  ·  Darker green = more waste diverted from landfill",
    "subtitleFontSize": 11,
    "subtitleColor": "#5c5c52"
  },
  "data": {
    "url": "data/vic_lga_2024.json",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "lookup": "properties.LGA_NAME24",
      "from": {
        "data": {"url": "data/waste_latest.csv"},
        "key": "lga_name",
        "fields": [
          "landfill_kg_per_person",
          "landfill_tonnes",
          "recovery_rate",
          "total_waste_tonnes",
          "lga_name"
        ]
      }
    },
    {"filter": "isValid(datum.recovery_rate)"}
  ],
  "projection": {"type": "mercator"},
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.6
  },
  "encoding": {
    "color": {
      "field": "recovery_rate",
      "type": "quantitative",
      "title": "Recovery rate",
      "scale": {"scheme": "greens"},
      "legend": {"format": ".0%"}
    },
    "tooltip": [
      {"field": "lga_name", "type": "nominal", "title": "Council"},
      {"field": "recovery_rate", "type": "quantitative", "title": "Recovery rate", "format": ".1%"},
      {"field": "total_waste_tonnes", "type": "quantitative", "title": "Total waste tonnes", "format": ",.0f"},
      {"field": "landfill_kg_per_person", "type": "quantitative", "title": "Landfill kg/person", "format": ".1f"}
    ]
  },
  "config": {"view": {"stroke": null}}
}
